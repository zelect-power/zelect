# === Runtime ===
PORT=3777
HOST=127.0.0.1
NODE_ENV=production

# === Database (PostgreSQL local) ===
# Заводится `CREATE USER zelect WITH PASSWORD '...'; CREATE DATABASE zelect_prod OWNER zelect;`
DATABASE_URL=postgres://zelect:__CHANGE_ME__@127.0.0.1:5432/zelect_prod

# === Payload CMS (заполнится на Этапе 2) ===
# PAYLOAD_SECRET=__generate_with__openssl_rand_base64_48__
# PAYLOAD_PUBLIC_SERVER_URL=https://zelect.com.ua

# === Email (на Этапе 3 — формы «Запит КП» и контактная) ===
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SUBMISSION_TO_EMAIL=

# === Analytics (Этап 5) ===
# NEXT_PUBLIC_GA_ID=
